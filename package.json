{
  "name": "justfit",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=client-app",
    "build": "npm run build --workspace=client-app",
    "lint": "npm run lint --workspace=client-app",
    "preview": "npm run preview --workspace=client-app",
    "smoke": "bash scripts/smoke.sh",
    "smoke:ratelimit": "bash scripts/smoke-ratelimit.sh",
    "test": "npm run test --workspace=client-app && npm run test --workspace=@justfit/shared",
    "e2e": "npx playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0"
  }
}
